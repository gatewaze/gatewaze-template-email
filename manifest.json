{
  "$schema": "https://gatewaze.com/schemas/email-boilerplate-manifest-v1.json",
  "name": "gatewaze-template-email",
  "version": "0.4.0",
  "description": "Gatewaze email boilerplate. React-Email project layout (`emails/` + `theme.ts` + `theme-fonts.tsx`) cloned per-newsletter on creation. The platform's react-email block registry surfaces the blocks listed in `enabled_blocks`; edition publishes write rendered HTML back to the cloned repo's `publish` branch. The TSX files in `emails/` are starter templates (Barebone style) that operators can preview locally with `email dev` and copy/customise.",
  "render_kind": "react-email",
  "comment": "When render_kind='react-email', the platform's email-blocks registry (gatewaze-modules/newsletters/admin/components/puck/email-blocks) is the source of truth for component implementations. This manifest enables specific componentIds and may override per-block defaults / labels. Per-tenant TSX components committed to this repo (under emails/) are surfaced as starter templates today; full runtime TSX compilation of arbitrary tenant components is Phase 2.",
  "enabled_blocks": [
    { "component_id": "header", "label": "Header", "category": "Navigation", "default_for_basic_template": true },
    { "component_id": "header_with_nav", "label": "Header with nav", "category": "Navigation" },
    { "component_id": "logo_header", "label": "Logo header", "category": "Navigation" },
    { "component_id": "footer", "label": "Footer", "category": "Navigation", "default_for_basic_template": true },
    { "component_id": "multi_column_footer", "label": "Footer with link columns", "category": "Navigation" },
    { "component_id": "social_icons_row", "label": "Social icons row", "category": "Navigation" },
    { "component_id": "hero", "label": "Hero", "category": "Marketing" },
    { "component_id": "content_section", "label": "Content section", "category": "Content", "default_for_basic_template": true },
    { "component_id": "ai_section", "label": "Helix AI content", "category": "Content", "default_for_basic_template": true },
    { "component_id": "weather", "label": "Weather", "category": "Content" },
    { "component_id": "heading", "label": "Heading", "category": "Content" },
    { "component_id": "heading_with_eyebrow", "label": "Heading with eyebrow", "category": "Content" },
    { "component_id": "text", "label": "Text", "category": "Content" },
    { "component_id": "pull_quote", "label": "Pull quote", "category": "Content" },
    { "component_id": "img", "label": "Image", "category": "Content" },
    { "component_id": "image_with_caption", "label": "Image with caption", "category": "Content" },
    { "component_id": "full_width_image", "label": "Full-width image", "category": "Content" },
    { "component_id": "bullet_list", "label": "Bullet list", "category": "Content" },
    { "component_id": "icon_list", "label": "Icon list", "category": "Content" },
    { "component_id": "markdown_content", "label": "Markdown", "category": "Content" },
    { "component_id": "markdown_blockquote", "label": "Markdown (blockquote)", "category": "Content" },
    { "component_id": "markdown_changelog", "label": "Markdown changelog", "category": "Content" },
    { "component_id": "two_column_features", "label": "Two-column features", "category": "Features" },
    { "component_id": "three_column_features", "label": "Three-column features", "category": "Features" },
    { "component_id": "feature_row_with_icon", "label": "Feature row (with icon)", "category": "Features" },
    { "component_id": "alternating_feature", "label": "Feature (image + text)", "category": "Features" },
    { "component_id": "feature_grid_2x2", "label": "Feature grid (2x2)", "category": "Features" },
    { "component_id": "featured_article", "label": "Featured article", "category": "Articles" },
    { "component_id": "article_card", "label": "Article card", "category": "Articles" },
    { "component_id": "article_with_image", "label": "Article with image", "category": "Articles" },
    { "component_id": "article_with_author", "label": "Article with author", "category": "Articles" },
    { "component_id": "article_list", "label": "Article list", "category": "Articles" },
    { "component_id": "compact_article", "label": "Compact article", "category": "Articles" },
    { "component_id": "testimonial_card", "label": "Testimonial card", "category": "Testimonials" },
    { "component_id": "testimonial_stack", "label": "Testimonial stack", "category": "Testimonials" },
    { "component_id": "stats_three_up", "label": "Stats (three up)", "category": "Stats" },
    { "component_id": "stat_with_description", "label": "Stat with description", "category": "Stats" },
    { "component_id": "avatar", "label": "Avatar", "category": "Avatars" },
    { "component_id": "avatar_with_name", "label": "Avatar with name", "category": "Avatars" },
    { "component_id": "avatar_row", "label": "Avatar row", "category": "Avatars" },
    { "component_id": "avatar_with_status", "label": "Avatar with status badge", "category": "Avatars" },
    { "component_id": "gallery_2_col", "label": "Gallery (2 col)", "category": "Gallery" },
    { "component_id": "gallery_3_col", "label": "Gallery (3 col)", "category": "Gallery" },
    { "component_id": "gallery_4_col", "label": "Gallery (4 col)", "category": "Gallery" },
    { "component_id": "gallery_mosaic", "label": "Gallery (mosaic)", "category": "Gallery" },
    { "component_id": "pricing_card", "label": "Pricing card", "category": "Pricing" },
    { "component_id": "pricing_comparison", "label": "Pricing comparison", "category": "Pricing" },
    { "component_id": "star_rating", "label": "Star rating", "category": "Feedback" },
    { "component_id": "thumbs_rating", "label": "Thumbs rating", "category": "Feedback" },
    { "component_id": "scale_rating", "label": "Scale rating", "category": "Feedback" },
    { "component_id": "button", "label": "Button", "category": "Action" },
    { "component_id": "cta_card", "label": "CTA card", "category": "Action" },
    { "component_id": "button_group", "label": "Button group", "category": "Action" },
    { "component_id": "link", "label": "Link", "category": "Action" },
    { "component_id": "link_with_arrow", "label": "Link (with arrow)", "category": "Action" },
    { "component_id": "container", "label": "Container", "category": "Layout" },
    { "component_id": "section", "label": "Section", "category": "Layout" },
    { "component_id": "section_background", "label": "Section (colored)", "category": "Layout" },
    { "component_id": "row", "label": "Row", "category": "Layout" },
    { "component_id": "column", "label": "Column", "category": "Layout" },
    { "component_id": "two_column_grid", "label": "Two-column grid", "category": "Layout" },
    { "component_id": "three_column_grid", "label": "Three-column grid", "category": "Layout" },
    { "component_id": "hr", "label": "Divider", "category": "Layout" },
    { "component_id": "labeled_divider", "label": "Divider with label", "category": "Layout" },
    { "component_id": "code_inline", "label": "Inline code", "category": "Code" },
    { "component_id": "code_inline_with_label", "label": "Inline code (with label)", "category": "Code" },
    { "component_id": "code_block", "label": "Code block", "category": "Code" },
    { "component_id": "code_block_with_filename", "label": "Code block (with filename)", "category": "Code" },
    { "component_id": "code_block_with_line_numbers", "label": "Code block (with line numbers)", "category": "Code" },
    { "component_id": "code_block_with_copy", "label": "Code block (with copy link)", "category": "Code" },
    { "component_id": "product_card", "label": "Product card", "category": "Ecommerce" },
    { "component_id": "product_grid", "label": "Product grid (3-up)", "category": "Ecommerce" },
    { "component_id": "cart_summary", "label": "Cart summary", "category": "Ecommerce" },
    { "component_id": "order_receipt", "label": "Order receipt", "category": "Ecommerce" },
    { "component_id": "shipping_tracker", "label": "Shipping tracker", "category": "Ecommerce" }
  ],
  "starter_templates": {
    "comment": "Full-edition TSX templates ported from react-email's Barebone demo. Operators can preview locally via `pnpm email:dev`, copy any of these as the starting point for a new edition, or use them as reference when authoring custom react-email blocks. The `entry` path is relative to repo root.",
    "theme_module": "emails/theme.ts",
    "fonts_module": "emails/theme-fonts.tsx",
    "templates": [
      { "id": "welcome", "label": "Welcome", "category": "Onboarding", "entry": "emails/welcome.tsx", "export": "WelcomeEmail" },
      { "id": "activation", "label": "Email confirmation", "category": "Transactional", "entry": "emails/activation.tsx", "export": "ConfirmEmail" },
      { "id": "password-reset", "label": "Password reset", "category": "Transactional", "entry": "emails/password-reset.tsx", "export": "PasswordResetEmail" },
      { "id": "feature-announcement", "label": "Feature announcement", "category": "Marketing", "entry": "emails/feature-announcement.tsx", "export": "FeatureAnnouncementEmail" },
      { "id": "product-update", "label": "Product update", "category": "Marketing", "entry": "emails/product-update.tsx", "export": "ProductUpdateEmail" },
      { "id": "subscription-confirmation", "label": "Subscription confirmation", "category": "Transactional", "entry": "emails/subscription-confirmation.tsx", "export": "SubscriptionConfirmation" },
      { "id": "subscription-update", "label": "Subscription update", "category": "Transactional", "entry": "emails/subscription-update.tsx", "export": "SubscriptionUpdate" },
      { "id": "text-only", "label": "Text-only", "category": "Plain", "entry": "emails/text-only.tsx", "export": "TextOnlyEmail" }
    ]
  },
  "publish_branch": "publish",
  "publish_layout": {
    "comment": "Where the publish-worker writes per-edition outputs.",
    "edition_html": "editions/{edition_id}.html",
    "edition_json": "editions/{edition_id}.json"
  }
}
